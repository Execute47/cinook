rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────────

    // Vérifie qu'un utilisateur est authentifié
    function isAuth() {
      return request.auth != null;
    }

    // Vérifie que l'utilisateur accède à ses propres données
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Vérifie que l'utilisateur est membre d'un cercle donné
    function isCircleMember(circleId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/circles/$(circleId)) &&
        request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)).data.members;
    }

    // Vérifie que l'utilisateur est admin d'un cercle donné
    function isCircleAdmin(circleId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/circles/$(circleId)) &&
        request.auth.uid == get(/databases/$(database)/documents/circles/$(circleId)).data.adminId;
    }

    // Vérifie que le requêteur partage au moins un cercle avec le profil cible
    // (supporte jusqu'à 3 cercles par utilisateur)
    function sharesCircle(circleIds) {
      return circleIds != null && circleIds.size() > 0 && (
        isCircleMember(circleIds[0]) ||
        (circleIds.size() > 1 && isCircleMember(circleIds[1])) ||
        (circleIds.size() > 2 && isCircleMember(circleIds[2]))
      );
    }

    // Vérifie que le requêteur est admin d'au moins un cercle partagé avec le profil cible
    function isAdminOfSharedCircle(circleIds) {
      return circleIds != null && circleIds.size() > 0 && (
        isCircleAdmin(circleIds[0]) ||
        (circleIds.size() > 1 && isCircleAdmin(circleIds[1])) ||
        (circleIds.size() > 2 && isCircleAdmin(circleIds[2]))
      );
    }

    // ─── Profils utilisateur ────────────────────────────────────────────────────

    match /users/{userId} {
      // Un utilisateur peut lire et écrire son propre profil
      allow read, write: if isOwner(userId);

      // Un admin d'un cercle commun peut modifier les circleIds d'un membre (expulsion)
      allow update: if isAuth() &&
        resource.data.circleIds != null &&
        isAdminOfSharedCircle(resource.data.circleIds) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['circleIds']);

      // Un membre du même cercle peut lire le profil (pour afficher les membres)
      allow read: if isAuth() && sharesCircle(resource.data.circleIds);

      // ─── Items personnels ──────────────────────────────────────────────────

      match /items/{itemId} {
        // Lecture et écriture de ses propres items
        allow read, write: if isOwner(userId);

        // Un membre du même cercle peut lire les items d'un autre membre
        allow read: if isAuth() &&
          exists(/databases/$(database)/documents/users/$(userId)) &&
          sharesCircle(get(/databases/$(database)/documents/users/$(userId)).data.circleIds);
      }
    }

    // ─── Cercles ────────────────────────────────────────────────────────────────

    match /circles/{circleId} {
      // Les membres du cercle peuvent lire ; tout utilisateur authentifié peut lire
      // pour résoudre un inviteToken (UUID difficile à deviner)
      allow read: if isCircleMember(circleId) || isAuth();

      // Seul l'admin peut créer le document cercle
      allow create: if isAuth();

      // L'admin peut tout modifier
      // OU un utilisateur authentifié peut s'ajouter lui-même via inviteToken
      // OU un membre peut se retirer lui-même (quitter le cercle)
      allow update: if isCircleAdmin(circleId) ||
        (isAuth() &&
         resource.data.inviteToken != null &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
         request.auth.uid in request.resource.data.members &&
         !(request.auth.uid in resource.data.members)) ||
        (isCircleMember(circleId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'adminId']) &&
         !(request.auth.uid in request.resource.data.members));

      allow delete: if isCircleAdmin(circleId);

      // ─── Recommandations ────────────────────────────────────────────────────

      match /recommendations/{recoId} {
        // Tous les membres du cercle peuvent lire et écrire des recommandations
        allow read, write: if isCircleMember(circleId);
      }

      // ─── Cinéclub ───────────────────────────────────────────────────────────

      match /cineclub/current {
        // Tous les membres du cercle peuvent lire et écrire le Cinéclub
        allow read, write: if isCircleMember(circleId);
      }
    }
  }
}
